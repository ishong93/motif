@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(X11)

# Xft support (if built with HAVE_XFT)
set(_motif_have_xft @HAVE_XFT@)
if(_motif_have_xft)
    find_dependency(PkgConfig)
    if(PkgConfig_FOUND)
        pkg_check_modules(XFT QUIET xft)
        pkg_check_modules(FONTCONFIG QUIET fontconfig)
    endif()
endif()
unset(_motif_have_xft)

include("${CMAKE_CURRENT_LIST_DIR}/MotifTargets.cmake")

check_required_components(Motif)
